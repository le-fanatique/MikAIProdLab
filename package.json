{
  "name": "mikaiproductionlab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:host": "next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "start:linux": "bash ./start-dev.sh",
    "setup:linux": "bash ./setup-linux.sh",
    "doctor:linux": "bash ./doctor.sh",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File ./setup-windows.ps1",
    "doctor:windows": "powershell -ExecutionPolicy Bypass -File ./doctor.ps1",
    "dev:all": "node scripts/run-prod-lab.mjs dev",
    "prod:all": "node scripts/run-prod-lab.mjs prod",
    "ai:init": "node scripts/agents-init.mjs",
    "ai:review": "node scripts/agents-review-instructions.mjs"
  },
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "dependencies": {
    "@xzdarcy/react-timeline-editor": "^1.0.0",
    "better-sqlite3": "^11.10.0",
    "drizzle-orm": "^0.44.2",
    "ffmpeg-ffprobe-static": "^6.1.1",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
