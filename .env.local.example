# MikAI Production Lab — local environment config
# Copy this file to .env.local and adjust as needed

PORT=3000
DB_PATH=./data/mikailab.db
DATA_DIR=./data
NODE_ENV=development

# ---------------------------------------------------------------------------
# LLM Provider — configure for V0.4 (leave commented until ready)
# ---------------------------------------------------------------------------
# Supported providers: ollama | openrouter | openai-compatible
# LLM_PROVIDER=ollama

# Base URL for the LLM API endpoint
# Ollama (local):       http://localhost:11434
# OpenRouter:           https://openrouter.ai/api/v1
# OpenAI-compatible:    your endpoint URL
# LLM_BASE_URL=http://localhost:11434

# Model identifier (provider-specific)
# Ollama examples:      llama3.2 / mistral / gemma2
# OpenRouter examples:  mistralai/mistral-7b-instruct / openai/gpt-4o
# LLM_MODEL=llama3.2

# API key — required for OpenRouter and OpenAI-compatible, leave empty for Ollama
# LLM_API_KEY=

# Provider-specific API key env vars (preferred over LLM_API_KEY for their provider)
# Used as fallback when the DB key is missing or empty.
# Set in .env.local so the dev server picks them up on start.
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-...

# Request timeout in milliseconds (default: 30000)
# LLM_TIMEOUT_MS=30000

# Note for Docker/Linux: if Ollama runs on the host, replace localhost with:
#   Docker Desktop (Windows/Mac): host.docker.internal
#   Linux Docker:                 172.17.0.1 (or docker network gateway IP)
