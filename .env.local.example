# MikAI Production Lab — local environment config
# Copy this file to .env.local and adjust as needed.
#
# SECURITY: Never commit .env.local. Never share API keys.
# .env.local is listed in .gitignore and will not be tracked by Git.

PORT=3000
DB_PATH=./data/mikailab.db
DATA_DIR=./data
NODE_ENV=development

# ---------------------------------------------------------------------------
# LLM Provider — set which provider MikAI uses for structured generation
# ---------------------------------------------------------------------------
# Supported providers: ollama | openrouter | openai-compatible
# LLM_PROVIDER=ollama

# Base URL for the LLM API endpoint
# Ollama (local):       http://localhost:11434
# OpenRouter:           https://openrouter.ai/api/v1
# OpenAI-compatible:    your endpoint URL
# LLM_BASE_URL=http://localhost:11434

# Model identifier (provider-specific)
# Ollama examples:      llama3.2 / mistral / gemma2
# OpenRouter examples:  mistralai/mistral-7b-instruct / openai/gpt-4o
# LLM_MODEL=llama3.2

# Legacy single API key (deprecated — prefer provider-specific keys below)
# LLM_API_KEY=

# Provider-specific API keys — preferred over LLM_API_KEY
# Used as fallback when the DB key is missing or empty.
# Set in .env.local so the dev server picks them up on start.
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=

# Request timeout in milliseconds (default: 30000)
# LLM_TIMEOUT_MS=30000

# ---------------------------------------------------------------------------
# ComfyUI
# ---------------------------------------------------------------------------
# Note: ComfyUI connection settings are primarily configured through the
# Settings UI in MikAI and stored in the local database.
# The environment variables below are reserved for future headless / Docker use
# and are not yet read by the runtime — use the Settings UI instead.
# COMFY_BASE_URL=http://127.0.0.1:8188
# COMFY_API_KEY=

# ---------------------------------------------------------------------------
# Storyboard panel extraction (OpenCV worker) — SEQGEN.STORYBOARD.EXTRACT.1
# ---------------------------------------------------------------------------
# Path/command for the Python interpreter used to run
# scripts/opencv_storyboard_extract.py. Requires opencv-python-headless and
# numpy: pip install opencv-python-headless numpy
# Default: python3. On some Windows setups `python3` resolves to a broken
# Microsoft Store stub — override to `python` (or a full path) if so.
# OPENCV_PYTHON_BIN=python3

# ---------------------------------------------------------------------------
# Ollama
# ---------------------------------------------------------------------------
# Note: Ollama base URL is configured through the Settings UI and stored in
# the local database. The variable below is reserved for future use.
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# ---------------------------------------------------------------------------
# Note for Docker/Linux:
# If Ollama or ComfyUI run on the host, replace localhost with:
#   Docker Desktop (Windows/Mac): host.docker.internal
#   Linux Docker:                 172.17.0.1 (or docker network gateway IP)
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# WSL (Windows Subsystem for Linux):
# If MikAI runs inside WSL and ComfyUI/Ollama run on the Windows host,
# 'localhost' inside WSL does NOT reach the Windows host.
# Find the Windows host IP with:
#   cat /etc/resolv.conf | grep nameserver | awk '{print $2}'
# Then configure these URLs in the MikAI Settings UI:
#   ComfyUI: http://<windows-host-ip>:8188
#   Ollama:  http://<windows-host-ip>:11434
# On Windows 11 with Docker Desktop installed, host.docker.internal may work.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# RunPod / cloud GPU:
# Mount a persistent volume so data survives pod restarts.
# Override the DB path to point to the persistent volume:
#   DB_PATH=/workspace/data/mikailab.db
# The following directories should live on the persistent volume:
#   data/              (SQLite database)
#   public/uploads/    (reference images)
#   public/outputs/    (generated outputs)
#   storage/           (other runtime files)
# Without a persistent volume, all local data will be lost on pod restart.
# ---------------------------------------------------------------------------
