# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep example, ignore local secrets
.env.local
.env*.local

# SQLite database (local data — not committed)
/data/
*.db
*.db-shm
*.db-wal

# user uploads — local only, not committed (folder tracked via .gitkeep)
/public/uploads/*
!/public/uploads/.gitkeep

# generated outputs — local only, not committed (folder tracked via .gitkeep)
/public/outputs/*
!/public/outputs/.gitkeep

# storage — local runtime files, not committed (folders tracked via .gitkeep)
/storage/*
!/storage/.gitkeep
/storage/outputs/*
!/storage/outputs/.gitkeep

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# .agents/ live workflow files (SUPERVISION.LOOP.1) — per-ticket scratch
# state, regenerated from .agents/templates/*, not tracked. See
# .agents/README.md.
.agents/current_task.md
.agents/claude_report.md
.agents/codex_review.md
.agents/codex_verdict.json
.agents/claude_followup.md
.agents/user_arbitration.md
